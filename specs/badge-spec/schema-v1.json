{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openauthcert.org/schema/badge/v1",
  "title": "OpenAuthCert Badge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "vendor",
    "application",
    "version",
    "badge_type",
    "status",
    "issued_at",
    "expires_at",
    "digital_signature"
  ],
  "properties": {
    "vendor": {
      "type": "string",
      "minLength": 1
    },
    "application": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "badge_type": {
      "type": "string",
      "enum": [
        "free-sso-idp",
        "free-ldap-support",
        "free-oidc-support",
        "free-saml-support",
        "multi-idp-ready"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "certified",
        "pending",
        "revoked",
        "denied"
      ]
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "Certification lapses after this instant; verifiers treat the badge as expired (not valid) once passed."
    },
    "revoked_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_urls": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "checks": {
      "type": "object",
      "description": "Live endpoints the nightly compliance probe re-tests to confirm the vendor still offers the certified feature for free.",
      "additionalProperties": false,
      "properties": {
        "oidc_discovery": {
          "type": "string",
          "format": "uri",
          "description": "OIDC discovery document URL (…/.well-known/openid-configuration)."
        },
        "saml_metadata": {
          "type": "string",
          "format": "uri",
          "description": "SAML 2.0 IdP/SP metadata URL."
        },
        "ldap": {
          "type": "string",
          "pattern": "^[A-Za-z0-9.-]+(:[0-9]{1,5})?$",
          "description": "LDAP endpoint as host or host:port (TCP reachability is probed; port defaults to 389)."
        },
        "docs": {
          "type": "string",
          "format": "uri",
          "description": "Public documentation URL probed for reachability / paywall regressions."
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "digital_signature": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/=]+$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "revoked"
          }
        }
      },
      "then": {
        "required": ["revoked_at"]
      }
    }
  ]
}
