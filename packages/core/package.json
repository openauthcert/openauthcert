{
  "name": "@openauthcert/core",
  "version": "0.0.0",
  "description": "Shared canonicalization, Ed25519 crypto, badge types, and JSON Schema validation for OpenAuthCert.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/index.browser.d.ts",
      "import": "./dist/index.browser.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "embed-schema": "node scripts/embed-schema.mjs",
    "build": "node scripts/embed-schema.mjs && tsc -b",
    "test": "node scripts/embed-schema.mjs && vitest run"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "typescript": "6.0.3",
    "vitest": "3.2.4"
  }
}
